# ============================================================================
# Proyecto Final de Carrera - .gitignore
# Backend Django + 3 frontends (React + React + Flutter) + deploy AWS
# ============================================================================

# ============================================================================
# CRITICO: variables de entorno y credenciales
# ============================================================================
# Todas las variantes de .env quedan bloqueadas; SOLO se permiten los .example
.env
.env.*
**/.env
**/.env.*
!**/.env.example
!**/.env.*.example
!.env.example
!.env.*.example

# Directorios de secretos
.secrets/
secrets/
.credentials/
credentials/
.keys/
.certs/

# Build-args con secretos para el deploy
build-args.env
**/build-args.env
!**/build-args.env.example

# Configuracion CFN con datos reales (mantener parameters.example.json en repo)
deploy/cloudformation/parameters.deploy.json
deploy/.tools/

# ============================================================================
# Certificados y claves criptograficas
# ============================================================================
*.pem
*.key
*.crt
*.cer
*.der
*.csr
*.p12
*.pfx
*.jks
*.keystore
*.truststore
*.p7b
*.p7c

# SSH
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*
authorized_keys
known_hosts

# GPG
*.gpg
*.asc
pubring.*
secring.*

# AWS
.aws/
aws-credentials*

# ============================================================================
# Bases de datos y backups (pueden contener PII de usuarios reales)
# ============================================================================
*.sqlite
*.sqlite3
db.sqlite3-journal
*.db
*.sql
*.dump
*.bak
*.backup
backup/
backups/
dumps/
dump.rdb
*.rdb
*.aof
pg_dump*
mongodump/

