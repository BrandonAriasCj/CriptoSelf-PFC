# Copia a .env y rellena. NO commitear .env real.
# Nombres deben coincidir con lo que lee Backend General/backend/settings.py.

# === Django ===
SECRET_KEY=cambia-esto-por-uno-largo-y-aleatorio
DEBUG=False

# Para que docker-compose lea la URI de ECR
ECR_BACKEND_IMAGE=<account-id>.dkr.ecr.<region>.amazonaws.com/criptoself-backend:latest

# Dominio publico (lo usa nginx.conf via envsubst)
BACKEND_DOMAIN=api.criptoself.com

# === Redis + Celery (alertas en tiempo real + digests periódicos) ===
# Estas las setea compose automáticamente para los containers que las necesitan;
# no hace falta definirlas en .env salvo que cambies el broker.
# REDIS_URL=redis://redis:6379/0
# CELERY_BROKER_URL=redis://redis:6379/0

# === Email (para verificacion / reset password) ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@criptoself.com

# === Google OAuth (login social) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://usuario.criptoself.com/auth/google/callback

# === GitHub OAuth (login social) ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://usuario.criptoself.com/auth/github/callback

# === Superuser bootstrap (opcional) ===
# Si dejas vacio, entrypoint no crea superuser. Lo creas con manage.py despues.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@criptoself.com
DJANGO_SUPERUSER_PASSWORD=
